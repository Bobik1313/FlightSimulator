### C++
# Object files
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Static libraries
*.a
*.lib

# Executables
*.exe
*.out

# Linker output
*.ilk
*.map
*.exp

# Debug files
*.dSYM/
*.idb
*.pdb


### C#
# Build results
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# User-specific files
*.suo
*.user

# Debug symbols
*.pdb

# NuGet Packages
*.nupkg
*.nuget.props
*.nuget.targets

# .NET build artifacts
artifacts/

# Publish output
publish/


### Unity
# Unity generated directories
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emory[Cc]aptures/

# Unity Package Manager
/Packages/*
!/Packages/manifest.json
!/Packages/packages-lock.json

# Asset meta files must be tracked
!/[Aa]ssets/**/*.meta

# Build output
*.apk
*.aab
*.unitypackage


### Unity autogenerated solution/project files
*.csproj
*.unityproj
*.sln
*.suo


### Native libraries outside Assets/Plugins
# Ignore compiled native libs everywhere else
*.so
*.dylib
*.dll


### Windows
# Windows thumbnail cache files
Thumbs.db

# Folder config file
[Dd]esktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows shortcuts
*.lnk


### Visual Studio
# User-specific files
*.suo
*.user

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Publish Web Output
*.[Pp]ublish.xml


### Unity native plugins
# Must be at the end to override *.dll / *.so / *.dylib ignores above
!/Assets/Plugins/**/*.dll
!/Assets/Plugins/**/*.so
!/Assets/Plugins/**/*.dylib
!/Assets/Plugins/**/*.bundle
!/Assets/Plugins/**/*.meta